# Frontend environment variables (Next.js public). Copy to .env.local for dev.

# Backend API base URL (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Phoenix workspace URL used for the "↗ Phoenix" deep links surfaced on rows.
# Set to the workspace you want judges/users to land in.
NEXT_PUBLIC_PHOENIX_URL=https://app.phoenix.arize.com

# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=false
GEMINI_MODEL=gemini-2.5-flash

# Arize Phoenix Cloud
PHOENIX_API_KEY=your-phoenix-api-key-here
PHOENIX_BASE_URL=https://app.phoenix.arize.com
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_PROJECT_NAME=phoenixloop

# Application
APP_ENV=development
APP_PORT=8000
DATABASE_URL=sqlite:///phoenixloop.db
FRONTEND_URL=http://localhost:3000

# Thresholds (hackathon defaults)
REPEATED_FAILURE_COUNT=2
REPEATED_FAILURE_RATE=0.30
CRITICAL_FAILURE_IMMEDIATE=true
COOLDOWN_MINUTES=30
RELEASE_SCORE_THRESHOLD=0.75
LATENCY_BUDGET_MS=10000

# Demo / auto-seed
# When true, auto-seed reads pre-recorded JSON fixtures from
# backend/tests/fixtures/seed/ instead of making live Gemini calls.
# Useful for pure-UI iteration without burning token budget.
LIGHTWEIGHT_DEMO=false
# When false (default), Phoenix LLM-based tool evals are skipped. The
# deterministic code-eval stack catches the same regressions for ~zero
# additional Gemini calls.
ENABLE_LLM_TOOL_EVALS=false
# When true, the lifespan skips the background full_loop_seed task and the
# DB stays empty after a fresh boot. Useful when you want a clean UI to
# demo the run-a-ticket flow from scratch.
SKIP_AUTOSEED=false

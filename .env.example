# Google Gemini
# Set GOOGLE_GENAI_USE_VERTEXAI=true to use Vertex AI (recommended for higher
# quota). With Vertex, the SDK reads ADC from ~/.config/gcloud (mount into the
# container via docker-compose.yml) and GOOGLE_API_KEY becomes a fallback.
# With Vertex unset/false, the SDK falls back to AI Studio + GOOGLE_API_KEY.
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Arize Phoenix Cloud
# IMPORTANT: Phoenix Cloud requires the /s/<your-space-handle> suffix on both
# BASE_URL and COLLECTOR_ENDPOINT. Find your handle at app.phoenix.arize.com →
# Settings → Workspace. Without it, the OTLP collector returns 401 and no
# traces reach Phoenix. The bare app.phoenix.arize.com host is the UI domain,
# not the API endpoint.
PHOENIX_API_KEY=your-phoenix-api-key-here
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/your-space-handle
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-handle
PHOENIX_PROJECT_NAME=phoenixloop

# Application
APP_ENV=development
APP_PORT=8000
DATABASE_URL=sqlite:///phoenixloop.db
FRONTEND_URL=http://localhost:3000

# Thresholds (hackathon defaults)
REPEATED_FAILURE_COUNT=2
REPEATED_FAILURE_RATE=0.30
CRITICAL_FAILURE_IMMEDIATE=true
COOLDOWN_MINUTES=30
RELEASE_SCORE_THRESHOLD=0.75
LATENCY_BUDGET_MS=10000

# Demo / auto-seed
# Default TRUE so a judge cloning the repo without API keys still gets a
# working UI driven by fixtures. Set to false (and fill PHOENIX_API_KEY +
# GOOGLE_API_KEY above) to make real Gemini calls and stream live traces to
# Phoenix Cloud. Fixtures live in backend/tests/fixtures/seed/.
LIGHTWEIGHT_DEMO=true
# When false (default), Phoenix LLM-based tool evals are skipped. The
# deterministic code-eval stack catches the same regressions for ~zero
# additional Gemini calls.
ENABLE_LLM_TOOL_EVALS=false
# When true, the lifespan skips the background full_loop_seed task and the
# DB stays empty after a fresh boot. Useful when you want a clean UI to
# demo the run-a-ticket flow from scratch.
SKIP_AUTOSEED=false
# When true, the demo seed coerces release-gate to PENDING_HUMAN_REVIEW so
# the demo always reaches the human-approval step. Leave false in production.
DEMO_FORCE_PENDING_REVIEW=true
# When true, the SSE healing loop deterministically strips citations from the
# 2nd and 4th tickets' agent responses so the citation_presence evaluator
# fails twice and the cluster crosses threshold. Required for the "Watch it
# heal" demo. Leave false in production.
DEMO_FORCE_FAILURE=true
